<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <input type="text" placeholder="username"
    <br>
    <br>
    <input type="password" placeholder="password"
    <br>
    <br>
    <br>
    <h>select your class</h>
    <br>
    <br>
        <label for="101">
     <input type="radio" value="class 10" name="class" id="101">class10
     <br>
     
     <label for="101">
     <input type="radio" value="class 12" name="class" id="102">class12


    <br> 
    <br>
    <h>select your subject</h>
    <br>
     <label for="HTML">
        <input type="checkbox" value="HTML" name="subject" id="101">HTML
    <label for="math">
        <br>
        <input type="checkbox" value="math" name="subject" id="102">math
        <br>
           <label for="phy">
        <input type="checkbox" value="phy" name="subject" id="103">phy
        <br>
           <label for="chem">
        <input type="checkbox" value="chem" name="subject" id="104">chem
        <br>
           <label for="eng">
        <input type="checkbox" value="eng" name="subject" id="105">eng
    <br>
    <br>
    <h>Select your city</h>
    <br>
    <select name="city">
        <option value="Delhi">Delhi</option>
         <option value="Brabanki">Barabanki</option>
          <option value="Lucknoow">Lucknow</option>
           <option value="Kanpur">Kanpur</option>
            <option value="Mumbai">Mumbai</option>
    </select>
    <br> 
    <br>
    <h>Give your feedback</h>
    <br>
    <textarea name="feedback" id="101" placeholder="please give your feedback 
    here">feedback</textarea>
</body>
</html>